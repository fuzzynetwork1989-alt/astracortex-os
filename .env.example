# Hybrid inference: local | cloud | hybrid
INFERENCE_MODE=hybrid
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_PLANNER_MODEL=deepseek-r1:8b
OLLAMA_EXECUTOR_MODEL=llama3.1:8b
OLLAMA_CRITIC_MODEL=deepseek-r1:8b
OLLAMA_CHAT_MODEL=qwen2.5:32b-instruct
OLLAMA_SEED_MODEL=qwen2.5:3b
OLLAMA_NEXUS_MODEL=llama3.1:8b
OLLAMA_SOVEREIGN_MODEL=llama3.1:70b

# Optional cloud brain (SpaceXAI / xAI)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_PLANNER_MODEL=grok-4.5
XAI_EXECUTOR_MODEL=grok-4.3
XAI_CRITIC_MODEL=grok-4.5

DEFAULT_TOKEN_BALANCE=1000000
JWT_SECRET=change-me-to-a-long-random-string
ALLOW_CORS_ALL=true
PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
UPLOAD_DIR=./data/uploads
DATABASE_URL=postgresql+asyncpg://astra:astra@localhost:5433/astracortex
REDIS_URL=redis://localhost:6380/0
EMBEDDING_DIM=1536
SEMANTIC_WRITE_THRESHOLD=0.65
HUMAN_LIKE_SYSTEM=true
PRODUCT_TIER_DEFAULT=nexus
NEXT_PUBLIC_API_URL=http://localhost:8000
