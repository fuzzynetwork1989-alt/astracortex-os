# Railway variables for HYBRID Cognitive OS
# Local Ollama (home/office) + cloud xAI failover + Railway API + Vercel UI

JWT_SECRET=change-me-to-a-long-random-string
INFERENCE_MODE=hybrid

# Cloud brain (failover / sovereign / no-Ollama path)
XAI_API_KEY=xai-your-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_PLANNER_MODEL=grok-4.5
XAI_EXECUTOR_MODEL=grok-4.3
XAI_CRITIC_MODEL=grok-4.5

# Optional: public tunnel to your home Ollama (ngrok/cloudflare tunnel)
# Leave empty on pure cloud; seed/nexus will use xAI after Ollama fails
OLLAMA_BASE_URL=
OLLAMA_ENABLED=true
OLLAMA_SEED_MODEL=qwen2.5:3b
OLLAMA_NEXUS_MODEL=llama3.1:8b
OLLAMA_PLANNER_MODEL=llama3.1:8b
OLLAMA_EXECUTOR_MODEL=llama3.1:8b

ALLOW_CORS_ALL=true
UPLOAD_DIR=/tmp/uploads
PUBLIC_API_URL=https://YOUR-SERVICE.up.railway.app
DEFAULT_TOKEN_BALANCE=1000000
HUMAN_LIKE_SYSTEM=true
PRODUCT_TIER_DEFAULT=seed
# DATABASE_URL / REDIS_URL injected by Railway plugins
